{
  "name": "codereview",
  "displayName": "Code Review Gate",
  "description": "Distrust-driven code review: per-line coverage gate plus file-level and cross-file AI analysis, powered by the GitHub CLI and VS Code's Copilot models.",
  "version": "0.0.26",
  "publisher": "codereview-dev",
  "private": true,
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codereview.startReview",
        "title": "Code Review: Start Review",
        "icon": "$(play)"
      },
      {
        "command": "codereview.openOrStart",
        "title": "Code Review: Open or Start Review",
        "icon": "$(checklist)"
      },
      {
        "command": "codereview.openInNewWindow",
        "title": "Code Review: Open in New Window",
        "icon": "$(window)"
      },
      {
        "command": "codereview.pickModel",
        "title": "Code Review: Select Analysis Model",
        "icon": "$(sparkle)"
      },
      {
        "command": "codereview.openWorkbench",
        "title": "Code Review: Open Workbench",
        "icon": "$(layout)"
      },
      {
        "command": "codereview.openFile",
        "title": "Code Review: Open Changed File"
      },
      {
        "command": "codereview.analyzeFile",
        "title": "Code Review: Analyze Current File",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "codereview.globalAnalysis",
        "title": "Code Review: Run Global Analysis",
        "icon": "$(graph)"
      },
      {
        "command": "codereview.showGlobalReport",
        "title": "Code Review: Show Global Report",
        "icon": "$(output)"
      },
      {
        "command": "codereview.submitConclusion",
        "title": "Code Review: Submit Conclusion",
        "icon": "$(check-all)"
      },
      {
        "command": "codereview.locateFinding",
        "title": "Code Review: Locate Finding"
      },
      {
        "command": "codereview.jumpToNextUnseen",
        "title": "Code Review: Jump to Next Unseen Line",
        "icon": "$(arrow-down)"
      }
    ],
    "configuration": {
      "title": "Code Review",
      "properties": {
        "codereview.language": {
          "type": "string",
          "enum": ["auto", "zh-CN", "en"],
          "enumDescriptions": [
            "跟随 VS Code 显示语言 / Follow VS Code display language",
            "始终使用简体中文",
            "Always use English"
          ],
          "default": "auto",
          "description": "Code Review 中所有 LLM 输出（findings、修复方案、解释、跨文件结论等）使用的语言。 / Language used by all LLM outputs (findings, fix proposals, explanations, global conclusions)."
        },
        "codereview.focusedWorkbench": {
          "type": "boolean",
          "default": false,
          "description": "打开 Code Review 工作台时自动关闭左侧栏并隐藏活动栏，让工作台占满主编辑区；关闭工作台后自动恢复。 / When opening the Code Review workbench, close the side bar and hide the activity bar so the workbench takes over the main editor area; restored automatically when the workbench is closed."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0"
  }
}
