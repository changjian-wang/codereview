{
  "name": "ai-coding-review",
  "displayName": "AI Coding Review",
  "description": "Distrust-driven code review: per-line coverage gate plus file-level and cross-file AI analysis, powered by the GitHub CLI and VS Code's Copilot models.",
  "version": "0.0.107",
  "publisher": "changjian-wang",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/changjian-wang/codereview.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codereview.startReview",
        "title": "%cmd.startReview%",
        "icon": "$(play)"
      },
      {
        "command": "codereview.openOrStart",
        "title": "%cmd.openOrStart%",
        "icon": "$(checklist)"
      },
      {
        "command": "codereview.openInNewWindow",
        "title": "%cmd.openInNewWindow%",
        "icon": "$(window)"
      },
      {
        "command": "codereview.pickModel",
        "title": "%cmd.pickModel%",
        "icon": "$(sparkle)"
      },
      {
        "command": "codereview.pickLanguage",
        "title": "%cmd.pickLanguage%",
        "icon": "$(globe)"
      },
      {
        "command": "codereview.openWorkbench",
        "title": "%cmd.openWorkbench%",
        "icon": "$(layout)"
      },
      {
        "command": "codereview.openFile",
        "title": "%cmd.openFile%"
      },
      {
        "command": "codereview.analyzeFile",
        "title": "%cmd.analyzeFile%",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "codereview.globalAnalysis",
        "title": "%cmd.globalAnalysis%",
        "icon": "$(graph)"
      },
      {
        "command": "codereview.showGlobalReport",
        "title": "%cmd.showGlobalReport%",
        "icon": "$(output)"
      },
      {
        "command": "codereview.submitConclusion",
        "title": "%cmd.submitConclusion%",
        "icon": "$(check-all)"
      },
      {
        "command": "codereview.locateFinding",
        "title": "%cmd.locateFinding%"
      },
      {
        "command": "codereview.jumpToNextUnseen",
        "title": "%cmd.jumpToNextUnseen%",
        "icon": "$(arrow-down)"
      }
    ],
    "configuration": {
      "title": "AI Coding Review",
      "properties": {
        "codereview.language": {
          "type": "string",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "enumDescriptions": [
            "%config.language.auto%",
            "%config.language.zh%",
            "%config.language.en%"
          ],
          "default": "en",
          "description": "%config.language.description%"
        },
        "codereview.focusedWorkbench": {
          "type": "boolean",
          "default": false,
          "description": "%config.focusedWorkbench.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0"
  }
}
